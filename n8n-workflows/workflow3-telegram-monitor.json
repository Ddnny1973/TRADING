    {
      "parameters": {
        "jsCode": "const chatId = $('Parse Command').first().json.chatId;\nconst detailResp = $('Get Grid Detail (HTTP)').first().json;\nconst pnlResp = $input.first().json;\nif (detailResp.statusCode !== 200) {\n  const body = detailResp.body || {};\n  return [{ json: { chatId, text: '⚠️ Error obteniendo la grid (HTTP ' + detailResp.statusCode + '): ' + (body.detail || JSON.stringify(body)) } }];\n}\nconst g = detailResp.body;\nconst orders = g.orders || [];\nconst filled = orders.filter(o => o.status === 'FILLED').length;\nconst openOrders = orders.filter(o => ['NEW', 'OPEN', 'PARTIALLY_FILLED'].includes(o.status)).length;\nconst statusEmoji = g.status === 'RUNNING' ? '🟢' : '🔴';\nlet text = statusEmoji + ' GRID ' + g.symbol + ' [' + g.status + ']\\n\\n' +\n  '🆔 ' + g.id + '\\n' +\n  '📐 Niveles: ' + g.levels + '\\n' +\n  '📊 Rango: ' + g.lower_price + ' – ' + g.upper_price + '\\n' +\n  '🛑 SL: ' + (g.stop_loss ?? 'N/A') + ' | 🎯 TP: ' + (g.take_profit ?? 'N/A') + '\\n' +\n  '⏳ Creado: ' + g.created_at + '\\n\\n' +\n  '📋 Órdenes: ' + orders.length + ' (✅ ' + filled + ' filled | 📭 ' + openOrders + ' abiertas)';\nif (pnlResp.statusCode === 200 && pnlResp.body) {\n  const p = pnlResp.body;\n  const pnlEmoji = Number(p.total_pnl) >= 0 ? '📈' : '📉';\n  text += '\\n\\n' + pnlEmoji + ' PnL (precio actual: ' + p.current_price + ')\\n' +\n    '   Realizado: ' + Number(p.realized_pnl).toFixed(4) + ' USDT\\n' +\n    '   No realizado: ' + Number(p.unrealized_pnl).toFixed(4) + ' USDT\\n' +\n    '   Total: ' + Number(p.total_pnl).toFixed(4) + ' USDT\\n' +\n    '   Posición neta: ' + p.net_position_qty;\n}\nreturn [{ json: { chatId, text } }];"
      },
