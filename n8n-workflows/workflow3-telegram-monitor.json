        "mode": "runOnceForEachItem",
        "jsCode": "const msg = $json.message || {};\nconst chatId = String((msg.chat && msg.chat.id) || '');\nconst text = (msg.text || '').trim();\nconst allowed = ($env.TELEGRAM_CHAT_ID || '').split(',').map(s => s.trim()).filter(Boolean);\nconst authorized = allowed.includes(chatId);\nconst parts = text.split(/\\s+/);\nconst command = (parts[0] || '').toLowerCase().split('@')[0];\nconst args = parts.slice(1);\nreturn { json: { chatId, text, command, args, authorized, username: (msg.from && msg.from.username) || '' } };"
