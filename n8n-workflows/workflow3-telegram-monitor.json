    {
      "parameters": {
        "jsCode": "const parse = $('Parse Command').first().json;\nconst chatId = parse.chatId;\nconst symbol = (parse.args[0] || '').toUpperCase();\nconst grids = $input.all().map(i => i.json).filter(g => g && g.id && String(g.symbol).toUpperCase() === symbol);\ngrids.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));\nconst grid = grids.find(g => g.status === 'RUNNING') || grids[0];\nif (!grid) {\n  return [{ json: { chatId, found: false, symbol } }];\n}\nreturn [{ json: { chatId, found: true, symbol, gridId: grid.id } }];"
      },
