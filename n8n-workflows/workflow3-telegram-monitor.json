    {
      "parameters": {
        "jsCode": "const chatId = $('Parse Command').first().json.chatId;\nconst grids = $input.all().map(i => i.json).filter(g => g && g.id);\nlet text;\nif (grids.length === 0) {\n  text = 'ℹ️ No hay grids RUNNING en este momento.\\n\\n🚀 Lanzar WF1: /trigger-wf1 confirm';\n} else {\n  const lines = grids.map(g => {\n    const ageH = ((Date.now() - new Date(g.created_at).getTime()) / 3600000).toFixed(1);\n    return '🟢 ' + g.symbol + '\\n' +\n      '   📐 Niveles: ' + g.levels + '\\n' +\n      '   📊 Rango: ' + g.lower_price + ' – ' + g.upper_price + '\\n' +\n      '   ⏳ Edad: ' + ageH + 'h\\n' +\n      '   🆔 ' + g.id;\n  });\n  text = '📊 GRIDS ACTIVOS (' + grids.length + ')\\n\\n' + lines.join('\\n\\n') + '\\n\\nℹ️ Detalle: /grid-detail SYMBOL';\n}\nreturn [{ json: { chatId, text } }];"
      },
