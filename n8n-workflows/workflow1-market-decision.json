    {
      "parameters": {
        "jsCode": "const resp = $json;\nconst statusCode = resp.statusCode;\nconst body = resp.body || {};\nconst decisionCtx = $('Parse AI Decision').item.json;\n\nif (statusCode === 200) {\n  return { json: { isError: false, alreadyExists: false, grid: body, symbol: decisionCtx.symbol, reasoning: decisionCtx.reasoning } };\n}\n\nconst detailRaw = body.detail !== undefined ? body.detail : body;\nconst detail = typeof detailRaw === 'string' ? detailRaw : JSON.stringify(detailRaw);\n\nif (statusCode === 400 && detail.toLowerCase().includes('already exists')) {\n  return { json: { isError: false, alreadyExists: true, grid: null, symbol: decisionCtx.symbol, reasoning: decisionCtx.reasoning, detail } };\n}\n\nreturn { json: { isError: true, alreadyExists: false, grid: null, symbol: decisionCtx.symbol, reasoning: decisionCtx.reasoning, statusCode, detail } };"
      },
