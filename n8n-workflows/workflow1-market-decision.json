      "id": "829a086b-17aa-471c-bf79-1fec53a796a8",
      "name": "Market Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -1520,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "const marketData = $json;\nconst ctx = $('Config').item.json;\nconst symbol = ctx.symbol;\n\nconst systemPrompt = `Eres el modulo de decision de un bot de grid trading en Binance Futures.\nRecibes datos de mercado ya calculados (no los recalcules). Tu unica tarea es decidir si conviene lanzar un grid ahora y con que parametros.\n\nReglas de criterio:\n- Si atr_pct (ATR/current_price) es muy bajo (<0.3%), el rango sera demasiado angosto para capturar movimiento -> considera no lanzar.\n- Si atr_pct es muy alto (>2%), el mercado puede estar en tendencia fuerte, no lateral -> los grids funcionan peor -> considera no lanzar o reducir gridCount.\n- gridCount razonable: entre 5 y 20 segun el ATR. Ejemplo: si atr_pct ~0.5%, usa 10-15 levels. Si atr_pct ~1.5%, usa 8-12 levels.\n- Siempre explica tu razonamiento en el campo reasoning ANTES de fijar launch.\n- lowerLimit/upperLimit: puedes ajustar los suggested_* si tienes razon fundamental, pero generalmente respeta los sugeridos.\n- Si launch=false, devuelve lowerLimit, upperLimit y gridCount como null.\n\nResponde UNICAMENTE en JSON valido, sin texto adicional.`;\n\nconst geminiRequestBody = {\n  systemInstruction: { parts: [{ text: systemPrompt }] },\n  contents: [{ role: 'user', parts: [{ text: JSON.stringify(marketData) }] }],\n  generationConfig: {\n    temperature: 0.4,\n    responseMimeType: 'application/json',\n    responseSchema: {\n      type: 'OBJECT',\n      properties: {\n        reasoning: { type: 'STRING' },\n        launch: { type: 'BOOLEAN' },\n        lowerLimit: { type: 'NUMBER', nullable: true },\n        upperLimit: { type: 'NUMBER', nullable: true },\n        gridCount: { type: 'INTEGER', nullable: true }\n      },\n      required: ['reasoning', 'launch', 'lowerLimit', 'upperLimit', 'gridCount']\n    }\n  }\n};\n\nreturn {\n  json: {\n    geminiRequestBody,\n    symbol,\n    suggested_quantity_per_order: marketData.suggested_quantity_per_order,\n    allocated_capital: marketData.allocated_capital,\n    suggested_stop_loss: marketData.suggested_stop_loss,\n    atr_period: ctx.atr_period,\n    atr_multiplier: ctx.atr_multiplier,\n    klines_interval: ctx.klines_interval\n  }\n};"
      },
      "id": "354b35a0-28ae-4b5c-b2b6-e7f2cc362417",
      "name": "Build Gemini Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1296,
        80
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.geminiRequestBody }}",
        "options": {}
      },
      "id": "a14c94fc-9493-4dfc-a03f-42c2f90aef29",
      "name": "Gemini: AI Decision",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -1088,
        80
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "NQnuuYpP2Pax6Nvr",
          "name": "Header Auth GeminiAI"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const geminiResponse = $json;\nconst rawText = geminiResponse?.candidates?.[0]?.content?.parts?.[0]?.text;\nif (!rawText) {\n  throw new Error('Respuesta de Gemini sin contenido de texto: ' + JSON.stringify(geminiResponse));\n}\n\nlet decision;\ntry {\n  decision = JSON.parse(rawText);\n} catch (e) {\n  throw new Error('No se pudo parsear JSON de Gemini: ' + rawText);\n}\n\nconst ctx = $('Build Gemini Request').item.json;\nconst configLevels = $('Config').item.json.levels;\n\n// Tope de seguridad: la IA puede sugerir su propio gridCount (5-20 segun el\n// prompt), pero nunca debe superar el 'levels' configurado manualmente en el\n// nodo Config -- eso limita la exposicion/cantidad de ordenes en fase de pruebas.\nconst cappedGridCount = decision.gridCount != null\n  ? Math.min(decision.gridCount, configLevels)\n  : decision.gridCount;\n\nreturn {\n  json: {\n    symbol: ctx.symbol,\n    reasoning: decision.reasoning,\n    launch: decision.launch === true,\n    lowerLimit: decision.lowerLimit,\n    upperLimit: decision.upperLimit,\n    gridCount: cappedGridCount,\n    suggested_quantity_per_order: ctx.suggested_quantity_per_order,\n    allocated_capital: ctx.allocated_capital,\n    suggested_stop_loss: ctx.suggested_stop_loss,\n    atr_period: ctx.atr_period,\n    atr_multiplier: ctx.atr_multiplier,\n    klines_interval: ctx.klines_interval\n  }\n};"
      },
      "id": "abf35d94-d138-46af-abf6-2f14764833ec",
      "name": "Parse AI Decision",
