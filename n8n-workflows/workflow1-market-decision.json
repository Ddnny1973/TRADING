        "jsonBody": "={{ { symbol: $('Config').item.json.symbol, levels: $('Get Auto Params (FIX 4)').item.json.params.levels, grid_type: 'GEOMETRIC', quantity_per_order: $('Get Auto Params (FIX 4)').item.json.params.risk_pct * $('Config').item.json.balance / ($('Get Auto Params (FIX 4)').item.json.params.levels * $('Get Auto Params (FIX 4)').item.json.current_price), atr_period: $('Get Auto Params (FIX 4)').item.json.params.atr_period, atr_multiplier: $('Get Auto Params (FIX 4)').item.json.params.atr_multiplier, klines_interval: $('Get Auto Params (FIX 4)').item.json.params.klines_interval, stop_loss: null, take_profit: null, max_duration_hours: null } }}",
