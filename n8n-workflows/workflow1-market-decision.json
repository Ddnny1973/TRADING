        "text": "={{ $json.alreadyExists ? ('ℹ️ Grid ya existia para ' + $json.autoParams.symbol + '\\n\\n💭 ' + $json.reasoning) : ('✅ Grid LANZADO\\n━━━━━━━━━━━━━━━━━━━━\\n📊 Symbol: ' + $json.grid.symbol + '\\n🆔 ID: ' + $json.grid.id.substring(0, 16) + '...\\n📈 Niveles: ' + $json.grid.levels + '\\n💰 Rango: ' + $json.grid.lower_price + ' - ' + $json.grid.upper_price + '\\n🎯 Órdenes: ' + $json.grid.orders.length + '\\n⚡ Leverage: ' + $json.autoParams.params.leverage + 'x\\n\\n💡 Parámetros (auto-derivados):\\n   • risk_pct: ' + $json.autoParams.params.risk_pct + '\\n   • atr_mult: ' + $json.autoParams.params.atr_multiplier + '\\n   • interval: ' + $json.autoParams.params.klines_interval + '\\n   • par elegido: ' + ($json.autoParams.symbol_selection?.method === 'auto' ? 'automático' : 'manual') + '\\n\\n💭 ' + $json.reasoning) }}",
