      "id": "87d5e9f1-5678-90ab-cdef-0123456789ab",
      "name": "IF: Grid Viable? (FIX 4)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -1504,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "const autoParams = $json;\nconst config = $('Config').item.json;\n\nconst systemPrompt = \"Eres el modulo de decision de un bot de grid trading en Binance Futures USDT-M.\\nRecibes parametros ya calculados y validados (grid_viable=true).\\nTu unica tarea es decidir si lanzar el grid con estos parametros.\\n\\nCONTEXTO QUE RECIBES:\\n- symbol: par elegido automaticamente por scoring (ER, volumen, ATR, funding)\\n- symbol_selection.top_3: los 3 mejores pares evaluados\\n- params.leverage: derivado de la volatilidad del par (ATR%)\\n- params.risk_pct: capital asignado como % del balance\\n- reasoning: explicacion de cada parametro\\n\\nPUEDES DECIDIR:\\n- launch=true: usar los parametros exactos recibidos\\n- launch=false: NO lanzar, explicar razon en reasoning\\n\\nNO PUEDES:\\n- Cambiar parametros (solo aprobar o rechazar)\\n- Ignorar grid_viable=false (si llega aqui ya fue filtrado)\\n- Asumir informacion que no esta en el JSON\\n\\nCRITERIOS PARA launch=false:\\n- ER del par seleccionado > 0.35 (tendencia, no lateral)\\n- Leverage > 5x con ATR% > 2% (demasiado agresivo)\\n- top_3 vacio o candidatos_evaluados < 5 (mercado sin opciones)\\n- Cualquier anomalia en los parametros que indique riesgo extremo\\n\\nResponde UNICAMENTE en JSON: {\\\"reasoning\\\": \\\"...\\\", \\\"launch\\\": true/false}\";\n\nconst geminiRequestBody = {\n  systemInstruction: { parts: [{ text: systemPrompt }] },\n  contents: [{ role: 'user', parts: [{ text: JSON.stringify(autoParams) }] }],\n  generationConfig: {\n    temperature: 0.3,\n    responseMimeType: 'application/json',\n    responseSchema: {\n      type: 'OBJECT',\n      properties: {\n        reasoning: { type: 'STRING' },\n        launch: { type: 'BOOLEAN' }\n      },\n      required: ['reasoning', 'launch']\n    }\n  }\n};\n\nreturn {\n  json: {\n    geminiRequestBody,\n    autoParams,\n    symbol: autoParams.symbol,\n    balance: config.balance\n  }\n};"
      },
      "id": "354b35a0-28ae-4b5c-b2b6-e7f2cc362417",
      "name": "Build Gemini Request (with derived params)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1280,
        64
      ]
    },
    {
      "parameters": {
        "jsCode": "const resp = $json;\n\n// 1) Formato LLM Chain / OpenAI en n8n: { text: \"...\" }\nlet text = null;\nif (typeof resp.text === 'string') {\n  text = resp.text;\n// 2) Formato OpenAI API crudo: choices[0].message.content\n} else if (resp.choices && resp.choices[0] && resp.choices[0].message) {\n  text = resp.choices[0].message.content;\n// 3) Formato Gemini HTTP antiguo: body.candidates[0].content.parts[0].text\n} else if (resp.body && resp.body.candidates && resp.body.candidates.length > 0) {\n  const content = resp.body.candidates[0].content;\n  if (content && content.parts && content.parts[0]) {\n    text = content.parts[0].text;\n  }\n}\n\nif (text) {\n  let clean = text.trim();\n  // El modelo a veces envuelve el JSON en ```json ... ```\n  const fence = clean.match(/```(?:json)?\\s*([\\s\\S]*?)\\s*```/);\n  if (fence) clean = fence[1];\n  try {\n    const parsed = JSON.parse(clean);\n    return { json: parsed };\n  } catch (e) {\n    return { json: { reasoning: 'Parse error: ' + clean, launch: false } };\n  }\n}\n\nreturn { json: { reasoning: 'AI error or no response', launch: false } };"
      },
      "id": "c9e0f1a2-b3c4-d5e6-f7a8-b9c0-d1e2f3a4",
      "name": "Parse AI Decision",
      "type": "n8n-nodes-base.code",
