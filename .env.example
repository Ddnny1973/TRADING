# ==========================================
# CONFIGURACIÓN BINANCE FUTURES API TESTNET
# ==========================================
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_secret_key_here
BINANCE_TESTNET_URL=https://demo-fapi.binance.com

# ==========================================
# CONFIGURACIÓN FASTAPI BACKEND
# ==========================================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
DEBUG_MODE=false
LOG_LEVEL=INFO

# ==========================================
# CONFIGURACIÓN REDIS
# ==========================================
REDIS_HOST=redis-trading
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change_this_redis_password

# ==========================================
# CONFIGURACIÓN POSTGRESQL
# ==========================================
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=secure_password_change_this
POSTGRES_DB=trading_history
POSTGRES_HOST=postgres-trading
POSTGRES_PORT=5432

# ==========================================
# CONFIGURACIÓN NOTIFICACIONES
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

WHATSAPP_API_URL=https://your-whatsapp-api-url
WHATSAPP_API_KEY=your_whatsapp_api_key

# ==========================================
# CONFIGURACIÓN GRID TRADING
# ==========================================
DEFAULT_GRID_SYMBOL=BTCUSDT
DEFAULT_GRID_LEVELS=10
DEFAULT_GRID_TYPE=GEOMETRIC
DEFAULT_RISK_PCT=0.02  # Risk per grid as fraction (0.01=1%, 0.02=2%, etc). Recommended: 0.01-0.02

# ==========================================
# CONFIGURACIÓN SEGURIDAD
# ==========================================
BINANCE_RECV_WINDOW=10000
API_RATE_LIMIT_THRESHOLD=1200
